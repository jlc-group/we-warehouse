# SQL Server Database Configuration (JLC Data)
DB_SERVER=YOUR_SQL_SERVER_ADDRESS
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_database_name

# API Server Configuration
PORT=3004
NODE_ENV=development

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:5178

# Local PostgreSQL Configuration (for warehouse data: products, inventory, etc.)
LOCAL_PG_HOST=localhost
LOCAL_PG_PORT=5432
LOCAL_PG_DATABASE=wewarehouse_local
LOCAL_PG_USER=postgres
LOCAL_PG_PASSWORD=your_postgres_password_here
