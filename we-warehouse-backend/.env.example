# ============================================
# We-Warehouse Backend - Environment Variables
# ============================================
# สำหรับ Developer เครื่องอื่น: อ่าน DEVELOPER_SETUP.md ก่อน!

# SQL Server Database Configuration (JHCSMILE - ใช้ได้เลย)
DB_SERVER=JHSERVER.DYNDNS.INFO\\SQLEXPRESS
DB_PORT=3306
DB_USER=readonly_user
DB_PASSWORD=your_db_password_here
DB_DATABASE=JHCSMILE

# API Server Configuration
PORT=3005
NODE_ENV=development

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:5178

# ============================================
# PostgreSQL Configuration
# ============================================
# สำหรับเครื่อง SERVER หลัก (มี PostgreSQL local):
LOCAL_PG_HOST=localhost
LOCAL_PG_PORT=5432

# สำหรับ Developer เครื่องอื่น (ต้องรัน cloudflared proxy ก่อน!):
# LOCAL_PG_HOST=localhost
# LOCAL_PG_PORT=15432

LOCAL_PG_DATABASE=wewarehouse_local
LOCAL_PG_USER=postgres
LOCAL_PG_PASSWORD=your_pg_password_here
