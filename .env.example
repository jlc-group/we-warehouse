# DATABASE MODE - Set to 'true' to use Local PostgreSQL via backend API
# Local backend (port 3005) now has /api/local routes for warehouse data
VITE_USE_LOCAL_DB=true

# App URL - ใช้สำหรับสร้าง QR Code (ถ้าไม่ตั้งค่าจะใช้ URL ปัจจุบัน)
# Production: เปลี่ยนเป็น URL จริงของเว็บ เช่น https://we-warehouse.your-domain.com
VITE_APP_URL=

# Supabase Configuration (Cloud - Production)
# Get these values from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# Self-Hosted PostgreSQL Configuration (Local - MIGRATED FROM SUPABASE)
VITE_PG_HOST=localhost
VITE_PG_PORT=5432
VITE_PG_DATABASE=wewarehouse_local
VITE_PG_USER=postgres
VITE_PG_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/wewarehouse_local

# External APIs - LOCAL BACKEND (Express server with JLC data on port 3005)
VITE_SALES_API_URL=http://localhost:3005/api
# Cloudflare Tunnel URL for mobile access (optional)
VITE_BACKEND_URL=
VITE_JLC_API_BASE=http://your-jlc-server-here

# Build Timestamp (auto-generated)
VITE_BUILD_TIMESTAMP=